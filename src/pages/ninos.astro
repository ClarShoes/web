---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navbar />
  <main style="max-width:1400px; margin:0 auto; padding:3rem 2rem;">
    <h1 style="font-family:'Bebas Neue',cursive; font-size:3rem; letter-spacing:3px; margin-bottom:1rem;">NINOS</h1>
    <p style="color:#666; margin-bottom:2rem;">Proximamente mas modelos para ninos.</p>
    <a href="/catalogo" style="background:#D4F240; color:#080808; padding:0.8rem 2rem; font-size:0.78rem; font-weight:700; letter-spacing:2px; text-transform:uppercase;">Ver Catalogo Completo</a>
  </main>
  <Footer />
</Layout>

