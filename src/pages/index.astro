---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';

const destacados = [
  { imagen: "/images/NEW-BALANCE-9060-X1.avif", alt: "New Balance 9060", nombre: "New Balance 9060", precio: "XXX.000", categoria: "", href: "/productos/new-balance-9060" },
  { imagen: "/images/Nike_Air_Max_BW.avif", alt: "Nike Air Max BW", nombre: "Nike Air Max BW", precio: "XXX.000", categoria: "Unisex", badge: "NUEVO" },
  { imagen: "/images/nike_cortez.png", alt: "Nike Cortez", nombre: "Nike Cortez", precio: "XXX.000", categoria: "Unisex" },
  { imagen: "/images/ZOOM-X1.png", alt: "Nike Zoom X", nombre: "Nike Zoom X", precio: "XXX.000", categoria: "Unisex", badge: "NUEVO" },
];
---

<Layout>
  <Navbar />

  <!-- COLLAGE HERO -->
  <section class="hero">
    <div class="collage">
      <div class="collage-item c1"><img src="/images/NEW-BALANCE-9060-X1.avif" alt="New Balance" /></div>
      <div class="collage-item c2"><img src="/images/nike_air_max_plus_tn-x.avif" alt="Nike TN" /></div>
      <div class="collage-item c3"><img src="/images/nike_cortez.png" alt="Nike Cortez" /></div>
      <div class="collage-item c4"><img src="/images/ON-CLOUD-RUNNING-X1.avif" alt="On Cloud" /></div>
      <div class="collage-overlay"></div>
    </div>

    <div class="hero-content">
      <p class="hero-tag">⚡ Zapatillas Importadas Triple A</p>
      <h1 class="hero-title">
        ESTILO<br/>
        QUE<br/>
        <span>HABLA</span>
      </h1>
      <p class="hero-sub">Cali · Colombia · Envios a todo el pais</p>
      <div class="hero-btns">
        <a href="/catalogo" class="btn-primary">Ver Catalogo</a>
        <a href="https://wa.me/573023582779" target="_blank" class="btn-outline">WhatsApp</a>
      </div>
    </div>
  </section>

  <!-- POR QUE COMPRARNOS -->
  <section class="razones">
    <div class="razones-grid">
      <div class="razon">
        <span class="razon-icon">📦</span>
        <h3>Envios a todo Colombia</h3>
        <p>Despachamos a cualquier ciudad del pais en 2 a 4 dias habiles.</p>
      </div>
      <div class="razon">
        <span class="razon-icon">⭐</span>
        <h3>Calidad Triple A</h3>
        <p>Zapatillas importadas con los mejores acabados y materiales.</p>
      </div>
      <div class="razon">
        <span class="razon-icon">💬</span>
        <h3>Atencion por WhatsApp</h3>
        <p>Respondemos rapido y te asesoramos para elegir tu modelo ideal.</p>
      </div>
      <div class="razon">
        <span class="razon-icon">✅</span>
        <h3>100+ modelos</h3>
        <p>Tenemos una gran variedad de marcas y estilos para todos.</p>
      </div>
    </div>
  </section>

  <!-- DESTACADOS -->
  <section class="destacados">
    <div class="seccion-header">
      <h2 class="seccion-titulo">DESTACADOS</h2>
      <a href="/catalogo" class="ver-todo">Ver todo el catalogo →</a>
    </div>
    <div class="productos-grid">
      {destacados.map(p => (
        <ProductCard
          imagen={p.imagen}
          alt={p.alt}
          nombre={p.nombre}
          precio={p.precio}
          categoria={p.categoria}
          badge={p.badge}
          href={p.href}
        />
      ))}
    </div>
  </section>

  <!-- BANNER REDES -->
  <section class="redes">
    <div class="redes-content">
      <h2>SIGUENOS EN REDES</h2>
      <p>Mira nuestros ultimos modelos en Instagram y TikTok</p>
      <div class="redes-btns">
        <a href="https://instagram.com/clars_shoes" target="_blank" class="btn-red instagram">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          @clars_shoes
        </a>
        <a href="https://tiktok.com/@clars_shoes" target="_blank" class="btn-red tiktok">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.52V6.76a4.85 4.85 0 01-1.02-.07z"/></svg>
          @clars_shoes
        </a>
      </div>
    </div>
  </section>

  <Footer />
</Layout>

<style>
  /* HERO */
  .hero {
    position: relative;
    height: 90vh;
    min-height: 500px;
    overflow: hidden;
  }

  .collage {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 3px;
  }

  .collage-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .collage-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(8,8,8,0.85) 0%, rgba(8,8,8,0.4) 60%, rgba(8,8,8,0.7) 100%);
  }

  .hero-content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2rem 3rem;
    max-width: 700px;
  }

  .hero-tag {
    font-size: 0.72rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--acento);
    font-weight: 600;
    margin-bottom: 1.2rem;
  }

  .hero-title {
    font-family: 'Bebas Neue', cursive;
    font-size: clamp(5rem, 12vw, 10rem);
    line-height: 0.88;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
  }

  .hero-title span { color: var(--acento); }

  .hero-sub {
    font-size: 0.85rem;
    color: rgba(242,239,233,0.6);
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-bottom: 2rem;
  }

  .hero-btns {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--acento);
    color: var(--negro);
    padding: 0.9rem 2rem;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }

  .btn-primary:hover { opacity: 0.85; }

  .btn-outline {
    background: transparent;
    color: var(--blanco);
    padding: 0.9rem 2rem;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 2px;
    text-transform: uppercase;
    border: 1px solid rgba(242,239,233,0.3);
    transition: border-color 0.2s;
  }

  .btn-outline:hover { border-color: var(--blanco); }

  /* RAZONES */
  .razones {
    padding: 5rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .razones-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--borde);
    border: 1px solid var(--borde);
  }

  .razon {
    background: var(--negro);
    padding: 2.5rem 2rem;
    text-align: center;
  }

  .razon-icon {
    font-size: 2rem;
    display: block;
    margin-bottom: 1rem;
  }

  .razon h3 {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 0.6rem;
    letter-spacing: 0.5px;
  }

  .razon p {
    font-size: 0.8rem;
    color: var(--gris);
    line-height: 1.7;
  }

  /* DESTACADOS */
  .destacados {
    padding: 0 2rem 5rem;
    max-width: 1400px;
    margin: 0 auto;
  }

  .seccion-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--borde);
  }

  .seccion-titulo {
    font-family: 'Bebas Neue', cursive;
    font-size: 2.5rem;
    letter-spacing: 3px;
  }

  .ver-todo {
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--acento);
    border-bottom: 1px solid var(--acento);
    padding-bottom: 2px;
    transition: opacity 0.2s;
  }

  .ver-todo:hover { opacity: 0.7; }

  .productos-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
  }

  /* REDES */
  .redes {
    background: var(--acento);
    padding: 4rem 2rem;
    text-align: center;
  }

  .redes-content h2 {
    font-family: 'Bebas Neue', cursive;
    font-size: 3rem;
    color: var(--negro);
    letter-spacing: 3px;
    margin-bottom: 0.5rem;
  }

  .redes-content p {
    color: rgba(0,0,0,0.6);
    font-size: 0.9rem;
    margin-bottom: 2rem;
  }

  .redes-btns {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-red {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    background: var(--negro);
    color: var(--blanco);
    padding: 0.8rem 1.8rem;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 1px;
    transition: opacity 0.2s;
  }

  .btn-red:hover { opacity: 0.85; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .razones-grid { grid-template-columns: repeat(2, 1fr); }
    .productos-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 600px) {
    .hero-content { padding: 2rem 1.5rem; }
    .razones-grid { grid-template-columns: 1fr; }
    .productos-grid { grid-template-columns: repeat(2, 1fr); gap: 0.5rem; }
    .seccion-header { flex-direction: column; align-items: flex-start; gap: 0.5rem; }
  }
</style>
