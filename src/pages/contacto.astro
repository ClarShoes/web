        target="_blank"
        class="contacto-card wa"
      >
        <div class="contacto-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
        </div>
        <div class="contacto-info">
          <h3>WhatsApp</h3>
          <p>Escribenos y te respondemos rapido</p>
          <span class="contacto-dato">+57 302 358 2779</span>
        </div>
        <div class="contacto-arrow">→</div>
      </a>

      <!-- INSTAGRAM -->
      <a 
        href="https://instagram.com/clars_shoes"
        target="_blank"
        class="contacto-card ig"
      >
        <div class="contacto-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
          </svg>
        </div>
        <div class="contacto-info">
          <h3>Instagram</h3>
          <p>Mira nuestros ultimos modelos</p>
          <span class="contacto-dato">@clars_shoes</span>
        </div>
        <div class="contacto-arrow">→</div>
      </a>

      <!-- TIKTOK -->
      <a 
        href="https://tiktok.com/@clars_shoes"
        target="_blank"
        class="contacto-card tt"
      >
        <div class="contacto-icon">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
            <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.18 8.18 0 004.79 1.52V6.76a4.85 4.85 0 01-1.02-.07z"/>
          </svg>
        </div>
        <div class="contacto-info">
          <h3>TikTok</h3>
          <p>Videos de nuestros modelos y estilos</p>
          <span class="contacto-dato">@clars_shoes</span>
        </div>
        <div class="contacto-arrow">→</div>
      </a>

      <!-- INFO -->
      <div class="contacto-card info">
        <div class="contacto-icon">📍</div>
        <div class="contacto-info">
          <h3>Ubicacion</h3>
          <p>Cali, Colombia</p>
          <span class="contacto-dato">Envios a todo el pais</span>
        </div>
      </div>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  .contacto {
    max-width: 900px;
    margin: 0 auto;
    padding: 4rem 2rem 6rem;
  }

  .contacto-header {
    margin-bottom: 3rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--borde);
  }

  .contacto-titulo {
    font-family: 'Bebas Neue', cursive;
    font-size: 4rem;
    letter-spacing: 4px;
  }

  .contacto-header p {
    color: var(--gris);
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    margin-top: 0.5rem;
  }

  .contacto-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contacto-card {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding: 1.8rem 2rem;
    border: 1px solid var(--borde);
    background: var(--gris2);
    transition: border-color 0.2s, transform 0.2s;
    text-decoration: none;
    color: var(--blanco);
  }

  .contacto-card:hover {
    border-color: var(--acento);
    transform: translateX(4px);
  }

  .contacto-icon {
    font-size: 2rem;
    width: 60px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wa .contacto-icon { color: #25D366; }
  .ig .contacto-icon { color: #E1306C; }
  .tt .contacto-icon { color: var(--blanco); }

  .contacto-info { flex: 1; }

  .contacto-info h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
  }

  .contacto-info p {
    font-size: 0.8rem;
    color: var(--gris);
    margin-bottom: 0.4rem;
  }

  .contacto-dato {
    font-size: 0.85rem;
    color: var(--acento);
    font-weight: 500;
  }

  .contacto-arrow {
    font-size: 1.5rem;
    color: var(--gris);
    transition: color 0.2s;
  }

  .contacto-card:hover .contacto-arrow { color: var(--acento); }

  .info { cursor: default; }
  .info:hover { transform: none; border-color: var(--borde); }

  @media (max-width: 600px) {
    .contacto-titulo { font-size: 2.5rem; }
    .contacto-card { padding: 1.2rem; gap: 1rem; }
  }
</style>