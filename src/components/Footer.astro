---
---
<header>
  <nav>
    <a href="/" class="logo">
      <img src="/images/logo.png" alt="Clar Shoes" class="logo-img" />
      <span class="logo-text">CLAR<em>&apos;</em>SHOES</span>
    </a>

    <ul class="nav-links">
      <li><a href="/">Inicio</a></li>
      <li><a href="/catalogo">Catalogo</a></li>
      <li><a href="/contacto">Contacto</a></li>
    </ul>

    <a 
      href="https://wa.me/573023582779?text=Hola!%20Vi%20su%20pagina%20y%20quiero%20mas%20informacion%20sobre%20las%20zapatillas"
      class="btn-whatsapp"
      target="_blank"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>

    <!-- Menú hamburguesa para celular -->
    <button class="hamburger" id="hamburger" aria-label="Menu">
      <span></span><span></span><span></span>
    </button>
  </nav>

  <!-- Menú mobile -->
  <div class="mobile-menu" id="mobileMenu">
    <a href="/">Inicio</a>
    <a href="/catalogo">Catalogo</a>
    <a href="/contacto">Contacto</a>
    <a href="https://wa.me/573023582779" target="_blank" class="mobile-wa">WhatsApp</a>
  </div>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(8,8,8,0.95);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--borde);
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    gap: 1rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }

  .logo-img {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
  }

  .logo-text {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.4rem;
    letter-spacing: 2px;
    color: var(--blanco);
  }

  .logo-text em {
    color: var(--acento);
    font-style: normal;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
    list-style: none;
  }

  .nav-links a {
    font-size: 0.78rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gris);
    font-weight: 500;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--blanco); }

  .btn-whatsapp {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: var(--acento);
    color: var(--negro);
    padding: 0.6rem 1.2rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }

  .btn-whatsapp:hover { opacity: 0.85; }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--blanco);
    transition: all 0.3s;
  }

  .mobile-menu {
    display: none;
    flex-direction: column;
    padding: 1rem 2rem 1.5rem;
    gap: 1rem;
    border-top: 1px solid var(--borde);
  }

  .mobile-menu a {
    font-size: 0.85rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--gris);
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--borde);
  }

  .mobile-menu .mobile-wa {
    color: var(--acento);
    border-bottom: none;
  }

  .mobile-menu.open { display: flex; }

  @media (max-width: 768px) {
    .nav-links, .btn-whatsapp { display: none; }
    .hamburger { display: flex; }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobileMenu');
  hamburger?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });
</script>
