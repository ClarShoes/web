---
interface Props {
  imagen: string;
  alt: string;
  nombre: string;
  precio: string;
  categoria: string;
  badge?: string;
  href?: string;
}

const { imagen, alt, nombre, precio, categoria, badge, href } = Astro.props;

const mensaje = encodeURIComponent(`Hola! Me interesa el modelo ${nombre}, precio $${precio}. Esta disponible?`);
const linkDestino = href || `https://wa.me/573023582779?text=${mensaje}`;
const esExterno = !href;
---

<a class="card" href={linkDestino} target={esExterno ? '_blank' : '_self'}>
  <div class="card-img">
    <img src={imagen} alt={alt} loading="lazy" />
    {badge && <span class="badge">{badge}</span>}
    <div class="card-overlay">
      <span class="btn-pedir">
        {href ? 'Ver modelo →' : 'Pedir por WhatsApp'}
      </span>
    </div>
  </div>
  <div class="card-info">
    {categoria && <span class="card-cat">{categoria}</span>}
    <h3 class="card-nombre">{nombre}</h3>
    <div class="card-precio">${precio}</div>
  </div>
</a>

<style>
  .card {
    display: block;
    background: var(--gris2);
    border: 1px solid var(--borde);
    overflow: hidden;
    transition: transform 0.3s, border-color 0.3s;
    color: var(--blanco);
    text-decoration: none;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: #444;
  }

  .card-img {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111;
  }

  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card:hover .card-img img {
    transform: scale(1.06);
  }

  .badge {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    background: var(--acento);
    color: var(--negro);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    z-index: 2;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .card:hover .card-overlay { opacity: 1; }

  .btn-pedir {
    display: block;
    background: var(--acento);
    color: var(--negro);
    padding: 0.7rem 1.2rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    width: 100%;
    text-align: center;
  }

  .card-info {
    padding: 1rem 1.2rem;
  }

  .card-cat {
    font-size: 0.6rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--acento);
    font-weight: 600;
  }

  .card-nombre {
    font-size: 0.95rem;
    font-weight: 500;
    margin: 0.3rem 0 0.5rem;
    color: var(--blanco);
  }

  .card-precio {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.3rem;
    color: var(--blanco);
    letter-spacing: 1px;
  }
</style>
