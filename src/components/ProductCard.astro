---
interface Props {
  imagen: string;
  alt: string;
  nombre: string;
  precio: string;
  categoria: string;
  badge?: string;
}

const { imagen, alt, nombre, precio, categoria, badge } = Astro.props;

const mensaje = encodeURIComponent(`Hola! Me interesa el modelo ${nombre}, precio $${precio}. Esta disponible?`);
const waLink = `https://wa.me/573023582779?text=${mensaje}`;
---

<div class="card">
  <div class="card-img">
    <img src={imagen} alt={alt} loading="lazy" />
    {badge && <span class="badge">{badge}</span>}
    <div class="card-overlay">
      <a href={waLink} target="_blank" class="btn-pedir">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
        </svg>
        Pedir por WhatsApp
      </a>
    </div>
  </div>
  <div class="card-info">
    <span class="card-cat">{categoria}</span>
    <h3 class="card-nombre">{nombre}</h3>
    <div class="card-precio">${precio}</div>
  </div>
</div>

<style>
  .card {
    background: var(--gris2);
    border: 1px solid var(--borde);
    overflow: hidden;
    transition: transform 0.3s, border-color 0.3s;
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: #444;
  }

  .card-img {
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #111;
  }

  .card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .card:hover .card-img img {
    transform: scale(1.06);
  }

  .badge {
    position: absolute;
    top: 0.8rem;
    left: 0.8rem;
    background: var(--acento);
    color: var(--negro);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    z-index: 2;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    opacity: 0;
    transition: opacity 0.3s;
  }

  .card:hover .card-overlay { opacity: 1; }

  .btn-pedir {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--acento);
    color: var(--negro);
    padding: 0.7rem 1.2rem;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 1px;
    text-transform: uppercase;
    width: 100%;
    justify-content: center;
    transition: opacity 0.2s;
  }

  .btn-pedir:hover { opacity: 0.9; }

  .card-info {
    padding: 1rem 1.2rem;
  }

  .card-cat {
    font-size: 0.6rem;
    letter-spacing: 3px;
    text-transform: uppercase;
    color: var(--acento);
    font-weight: 600;
  }

  .card-nombre {
    font-size: 0.95rem;
    font-weight: 500;
    margin: 0.3rem 0 0.5rem;
    color: var(--blanco);
  }

  .card-precio {
    font-family: 'Bebas Neue', cursive;
    font-size: 1.3rem;
    color: var(--blanco);
    letter-spacing: 1px;
  }
</style>